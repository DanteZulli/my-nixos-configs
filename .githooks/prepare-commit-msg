#!/usr/bin/env bash
set -uo pipefail

COMMIT_MSG_FILE=$1

# skip if user already wrote a message
if grep -q '^[a-zA-Z0-9]' "$COMMIT_MSG_FILE" 2>/dev/null; then
  exit 0
fi

MSGS=()

while IFS=$'\t' read -r status file; do
  case "$status" in
    A) MSGS+=("add: $file") ;;
    M) MSGS+=("update: $file") ;;
    D) MSGS+=("remove: $file") ;;
    R*) MSGS+=("rename: ${file#* -> }") ;;
  esac
done < <(git diff --cached --name-status)

if [ ${#MSGS[@]} -gt 0 ]; then
  printf "%s\n" "${MSGS[@]}" >"$COMMIT_MSG_FILE"
else
  echo "nothing staged" >"$COMMIT_MSG_FILE"
fi
